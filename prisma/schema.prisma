// =============================================================================
//  ESQUEMA ESPEJO — NO EDITAR AQUI
//
//  La fuente de verdad es "2- Nesux Landing/prisma/schema.prisma".
//  Esta app comparte la MISMA base de datos que Nesux y el resto de negocios.
//
//  NUNCA ejecutes 'prisma db push' ni 'prisma migrate' desde este proyecto:
//  este esquema podria quedar desfasado respecto al de Nesux y Prisma ofreceria
//  BORRAR las tablas que aqui no aparezcan. Los cambios de esquema se hacen
//  siempre en Nesux, y luego se copia el archivo aqui.
//
//  Copiado el 2026-07-21.
// =============================================================================

generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// Cada negocio de Nesux (Trading Academy, IA, Litio, VS Code…).
// Guarda su identidad y, opcionalmente, sus propias credenciales de cobro.
// Si una credencial es null, se usa la global del .env (compatibilidad hacia atrás).
model Business {
  id        String   @id @default(cuid())
  slug      String   @unique // "trading" | "ia" | "litio" | "vscode"
  name      String
  isActive  Boolean  @default(true)

  // --- Config del BOT por negocio (Fase 4 multi-negocio) ---
  tagline         String?  // frase corta de qué hace
  personaStyle    String?  // tono/personalidad del bot para este negocio
  botKnowledge    String?  // conocimiento base en texto (además del inventario)
  contactEmail    String?
  contactWhatsapp String?
  website         String?
  subscribed      Boolean  @default(true) // mensualidad al día (para cortar el bot si no paga)

  // Datos/credenciales de cobro por negocio (opcionales)
  bankAccounts         Json?   // array de cuentas bancarias para transferencia
  stripeSecretKey      String?
  stripeWebhookSecret  String?
  paypalClientId       String?
  paypalClientSecret   String?
  nowpaymentsApiKey    String?
  nowpaymentsIpnSecret String?

  apiKey    String?  @unique // clave para que el negocio consuma la API (futuro)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  members       UserBusiness[]
  payments      Payment[]
  courses       Course[]
  subscriptions Subscription[]
  leads         Lead[]
  products      Product[]
  botProducts   BotProduct[]

  @@index([slug])
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  // Negocio por el que se registró la PRIMERA vez (de dónde vino).
  // Para saber a qué negocios pertenece HOY, mirar la relación `businesses`:
  // una misma persona puede estar en Trading y en Litio a la vez.
  businessId        String?
  business          Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  businesses        UserBusiness[]
  password          String
  firstName         String
  lastName          String
  whatsappNumber    String
  role              String    @default("user")
  emailVerified     DateTime?
  verificationToken String?   @unique
  tokenExpiry       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // --- Gestión de cuenta (panel admin) ---
  status            String    @default("active") // active | suspended | deleted
  suspendedReason   String?
  suspendedUntil    DateTime?
  deletedAt         DateTime? // soft delete (restaurable)
  lastLoginAt       DateTime?

  // --- Identidad y credenciales generadas ---
  clientId           String?   @unique // ID legible tipo "JH1001"
  tempPassword       String?            // clave temporal generada (visible para admin hasta el 1er cambio)
  mustChangePassword Boolean   @default(false)
  passwordChangedAt  DateTime?

  chatSessions      ChatSession[]
  courseAccess      UserCourseAccess[]
  progress          UserProgress[]
  subscriptions     Subscription[]
  payments          Payment[]
  notes             UserNote[]    @relation("UserNotes")
  pageVisits        PageVisit[]

  @@index([status])
  @@index([role])
  @@index([createdAt])
  @@index([businessId])
}

// A qué negocios pertenece una persona.
//
// La cuenta es ÚNICA en todo Nesux: mismo correo, mismo WhatsApp, misma
// contraseña y mismo ID de cliente. Si alguien que ya es alumno de Trading se
// inscribe en Litio, NO se crea otro usuario: se le añade una fila aquí y pasa
// a estar en los dos. Cada negocio lo ve en su panel como alumno suyo.
model UserBusiness {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, businessId])
  @@index([businessId])
}

// Suscripción de un usuario a un plan. currentPeriodEnd define el vencimiento:
// si ya pasó y no se renovó, el usuario está "moroso".
model Subscription {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId       String?
  business         Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  plan             String    // basico | intermedio | profesional | vip
  status           String    @default("active") // active | past_due | canceled | expired
  amount           Float     @default(0)
  startedAt        DateTime  @default(now())
  currentPeriodEnd DateTime
  canceledAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  payments         Payment[]

  @@index([userId])
  @@index([businessId])
  @@index([status])
  @@index([currentPeriodEnd])
}

// Cada cobro realizado (para reportes financieros y estado al-día/moroso).
model Payment {
  id                String        @id @default(cuid())
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId        String?
  business          Business?     @relation(fields: [businessId], references: [id], onDelete: SetNull)
  subscriptionId    String?
  subscription      Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  courseId          String?       // producto/curso comprado
  productId         String?       // artículo del catálogo que se compró
  product           Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  amount            Float
  currency          String        @default("USD")
  method            String        // crypto | stripe | paypal | bank_transfer | manual
  status            String        @default("pending") // pending | paid | failed | refunded
  reference         String?       // referencia/concepto (ej. ID del alumno en transferencia)
  providerPaymentId String?       // ID del procesador (NOWPayments/Stripe/PayPal)
  providerMetadata  Json?         // respuesta completa del procesador
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt

  @@index([userId])
  @@index([businessId])
  @@index([productId])
  @@index([status])
  @@index([paidAt])
  @@index([providerPaymentId])
}

// Notas internas del administrador sobre un usuario.
model UserNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserNotes", fields: [userId], references: [id], onDelete: Cascade)
  authorId  String   // id del admin que la escribió
  body      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Registro de acciones administrativas (auditoría: quién hizo qué y cuándo).
model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String?
  action     String   // p.ej. user.suspend, user.update, payment.create
  targetType String?  // user | course | payment | ...
  targetId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

// Tracking de navegación: páginas visitadas y tiempo en cada una.
model PageVisit {
  id        String    @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String?   // id de sesión de navegador
  path      String
  enteredAt DateTime  @default(now())
  leftAt    DateTime?
  durationMs Int      @default(0)
  referrer  String?
  userAgent String?

  @@index([userId])
  @@index([enteredAt])
  @@index([path])
}

// Ajustes globales configurables desde el panel (clave/valor).
// Ej: "password_change_days" = "15", "client_seq" = "1000".
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Lead {
  id             String    @id @default(cuid())
  businessId     String?
  business       Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  email          String
  firstName      String?
  lastName       String?
  whatsappNumber String?
  source         String?   @default("website")
  status         String    @default("new")
  ownerName      String?
  followUpAt     DateTime?
  lastContactAt  DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([businessId])
  @@index([status])
  @@index([followUpAt])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model ChatSession {
  id                 String        @id
  userId             String?
  user               User?         @relation(fields: [userId], references: [id])
  startedAt          DateTime      @default(now())
  lastActiveAt       DateTime      @default(now())
  totalInteractionMs Int           @default(0)
  attendanceDate     DateTime      @default(now())
  userAgent          String?
  messages           ChatMessage[]
  topics             ChatTopic[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  isEdited  Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model ChatTopic {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  topic     String
  source    String      @default("keyword")
  createdAt DateTime    @default(now())
}

model Course {
  id          String             @id @default(cuid())
  businessId  String?
  business    Business?          @relation(fields: [businessId], references: [id], onDelete: SetNull)
  slug        String             @unique
  title       String
  description String
  imageUrl    String?
  price       Float              @default(0)
  isPublished Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  modules     CourseModule[]
  userAccess  UserCourseAccess[]
}

model CourseModule {
  id          String          @id @default(cuid())
  courseId    String
  course      Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lessons     CourseLesson[]
}

model CourseLesson {
  id          String            @id @default(cuid())
  moduleId    String
  module      CourseModule      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  description String?
  content     String?
  order       Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  resources   CourseResource[]
  progress    UserProgress[]
}

model CourseResource {
  id         String       @id @default(cuid())
  lessonId   String
  lesson     CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type       String
  title      String
  url        String
  order      Int
  createdAt  DateTime     @default(now())
}

model UserCourseAccess {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  grantedAt   DateTime @default(now())
  expiresAt   DateTime?
  paymentInfo String?
  paymentId   String?  // pago que originó este acceso

  @@unique([userId, courseId])
}

model UserProgress {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed   Boolean      @default(false)
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@unique([userId, lessonId])
}

// --- Recursos: departamentos (categorías por curso o bot). El contenido va aparte. ---
model ResourceDept {
  id          String   @id @default(cuid())
  name        String
  kind        String   @default("curso") // "curso" | "bot"
  icon        String?  // emoji opcional
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([kind])
}

// --- Publicidad: cupones de descuento ---
model Coupon {
  id           String    @id @default(cuid())
  code         String    @unique
  type         String    @default("percent") // "percent" | "fixed"
  value        Float                          // 10 = 10% (percent) o 10 = $10 (fixed)
  businessSlug String?                        // opcional: limitar a un negocio
  active       Boolean   @default(true)
  expiresAt    DateTime?
  maxUses      Int?                           // null = ilimitado
  usedCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

// --- Archivos subidos (biblioteca de material: documentos, imágenes, videos cortos) ---
model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  name      String
  type      String   @default("document") // "image" | "video" | "document"
  size      Int      @default(0)
  context   String   @default("publicidad") // dónde se usa
  createdAt DateTime @default(now())

  @@index([context])
}

// --- Historial de mensajes enviados (anuncios por email / WhatsApp) ---
// Se organiza como carpetas en el panel: Sección (comunicacion|publicidad) -> Negocio -> mensajes.
model SentMessage {
  id            String   @id @default(cuid())
  section       String   @default("comunicacion") // "comunicacion" | "publicidad"
  channel       String   @default("email")        // "email" | "whatsapp"
  businessSlug  String   @default("")             // "" = todos los negocios
  businessLabel String   @default("Todos los negocios")
  title         String                            // asunto/título del mensaje
  html          String                            // cuerpo del mensaje ya renderizado (HTML)
  recipients    Int      @default(0)              // nº de destinatarios
  sentAt        DateTime @default(now())

  @@index([section, businessSlug])
  @@index([sentAt])
}

// --- Correo: bitácora de respuestas ENVIADAS desde la bandeja del panel ---
model EmailLog {
  id           String   @id @default(cuid())
  business     String   @default("trading")
  toAddr       String
  toName       String   @default("")
  subject      String
  html         String   // cuerpo enviado (con formato)
  attachments  String   @default("[]") // JSON: [{name,url}]
  createdAt    DateTime @default(now())

  @@index([business])
  @@index([createdAt])
}

// --- WhatsApp: contacto/conversación entrante (Cloud API) ---
model WaContact {
  id           String      @id @default(cuid())
  waId         String      @unique // número del cliente (solo dígitos, con código de país)
  name         String?     // nombre de perfil de WhatsApp
  state        String      @default("new") // estado del flujo del bot
  lastInboundAt DateTime?  // último mensaje que ENVIÓ el cliente (para la ventana de 24h)
  keepaliveAt  DateTime?   // último recordatorio "sesión por expirar" enviado (evita repetir)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  messages     WaMessage[]

  @@index([lastInboundAt])
}

// Inventario que el bot de WhatsApp menciona en la conversación (precios "de boca").
// Se llamaba Product, pero ese nombre lo ocupa ahora el catálogo de venta real
// (el que se cobra y se referencia desde Payment). Son cosas distintas.
model BotProduct {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  price       String?  // texto libre: "$149.99", "RD$2,500/mes"...
  description String?
  url         String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([businessId, active])
}

// Catálogo de venta: lo que el cliente compra y a lo que apunta un Payment.
// Viene de la app de Trading, que ya lo tenía en producción con datos reales.
model Product {
  id             String    @id @default(cuid())
  businessId     String?
  business       Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  kind           String    // "course" | "bot" | "plan"
  slug           String    @unique
  name           String
  subtitle       String?
  description    String    @default("")
  imageUrl       String?
  price          Float     @default(0)
  originalPrice  Float?    // precio tachado / de referencia (opcional)
  currency       String    @default("USD")
  badge          String?   // ej. "Más vendido", "VIP"
  features       Json?     // lista de beneficios (string[])
  grantsCourseId String?   // curso que desbloquea al comprar (para kind=course|plan)
  isPublished    Boolean   @default(true)
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  payments       Payment[]

  @@index([businessId])
  @@index([kind])
  @@index([isPublished])
}

// --- UNIFICACIÓN Fase 3: IDENTIDAD única (una persona a través de los canales) ---
model Identity {
  id        String       @id @default(cuid())
  email     String?      @unique // clave cuando está logueado / dejó su correo
  waId      String?      @unique // clave del canal WhatsApp (número)
  name      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  memory    MemoryTurn[]
}

// Memoria COMPARTIDA entre canales (web, WhatsApp): turnos de conversación por persona.
model MemoryTurn {
  id         String   @id @default(cuid())
  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  channel    String   // "web" | "whatsapp" | ...
  role       String   // "user" | "assistant"
  content    String
  createdAt  DateTime @default(now())

  @@index([identityId, createdAt])
}

// --- WhatsApp: AGENDA / recordatorios de eventos (los agenda el creador CJ) ---
model Reminder {
  id         String    @id @default(cuid())
  ownerWaId  String    // quién lo agendó (el creador identificado)
  targetWaId String    // a quién se le recuerda (por defecto, el mismo owner)
  text       String    // qué recordar (el evento)
  fireAt     DateTime  // cuándo dispararlo (en UTC)
  recurring  String?   // null | "daily" | "weekly" | "monthly"
  voice      Boolean   @default(false) // enviar como nota de voz
  sent       Boolean   @default(false) // ya disparado (para los de una sola vez)
  canceled   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([fireAt, sent, canceled])
  @@index([ownerWaId])
}

// --- WhatsApp: bitácora de mensajes (entrantes y salientes) ---
model WaMessage {
  id        String    @id @default(cuid())
  contactId String
  contact   WaContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  wamid     String?   @unique // id del mensaje en Meta (para no duplicar)
  direction String    // "in" | "out"
  type      String    @default("text") // text | template | image | ...
  body      String?   // texto del mensaje
  createdAt DateTime  @default(now())

  @@index([contactId])
}