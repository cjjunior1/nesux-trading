# Transferencia bancaria (se muestran en el checkout)
# Opción A — una sola cuenta:
BANK_NAME=""
BANK_ACCOUNT_NUMBER=""
BANK_ACCOUNT_HOLDER="Trading a Otro Nivel"
# Opción B — VARIAS cuentas (JSON, tiene prioridad sobre la cuenta única):
